---
// src/pages/index.astro — one page Medianeras.
// Secciones: Navbar, Hero, Quiénes (R01), Qué hacemos (R02), Oferta (R03), Contacto (R05), Footer (R06).
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SectionHero from '../components/SectionHero.astro';
import SectionQuienes from '../components/SectionQuienes.astro';
import SectionQueHacemos from '../components/SectionQueHacemos.astro';
import SectionOferta from '../components/SectionOferta.astro';
import SectionContacto from '../components/SectionContacto.astro';
import SectionTestimonios from '../components/SectionTestimonios.astro';
import Footer from '../components/Footer.astro';
import { getActividades, getEquipo, getConfig, getTestimonios } from '../lib/cms';
import { localBusinessSchema, eventSchema } from '../lib/schema';

const [actividades, equipo, config, testimonios] = await Promise.all([
  getActividades(),
  getEquipo(),
  getConfig(),
  getTestimonios(),
]);

const site = (Astro.site ?? Astro.url).origin;
const jsonLd = [
  localBusinessSchema(config, site),
  ...actividades
    .filter((a) => a.estado !== 'cerrado')
    .map((a) => eventSchema(a, site))
    .filter((e): e is NonNullable<typeof e> => e !== null),
];
---

<Layout
  title="medianeras — espacio cultural de lectura, escritura y pensamiento"
  jsonLd={jsonLd}
>
  <Navbar />
  <main>
    <SectionHero />
    <SectionQuienes equipo={equipo} config={config} />
    <SectionQueHacemos config={config} />
    <SectionOferta actividades={actividades} />
    <SectionTestimonios testimonios={testimonios} />
    <SectionContacto config={config} />
  </main>
  <Footer config={config} />
</Layout>

---
// SectionTestimonios.astro — pila vertical de cards, controles a la derecha, sin dots.
import type { Testimonio } from '../lib/types';
interface Props { testimonios: Testimonio[]; }
const { testimonios } = Astro.props;
---
<section class="seccion testimonios" id="testimonios" aria-labelledby="test-titulo">
  <img
    class="testimonios__circulo"
    src="/brand/svg_elements/circle/amamos_leer.svg"
    alt=""
    aria-hidden="true"
    width="160"
    height="160"
    loading="lazy"
  />
  <div class="contenedor">
    <p class="eyebrow">Lo que dicen</p>
    <h2 id="test-titulo" class="label-seccion">La conversación sigue</h2>

    <div class="test-layout">

      <!-- Pila de cards -->
      <div class="test-pila">
        <div class="pila__ghost pila__ghost--2" aria-hidden="true"></div>
        <div class="pila__ghost pila__ghost--1" aria-hidden="true"></div>

        <div class="pila__track" role="region" aria-label="Testimonios de participantes" aria-live="polite" aria-atomic="true">
          {testimonios.map((t, i) => (
            <div
              class={`pila__item${i === 0 ? ' es-activo' : ''}`}
              data-index={i}
              aria-hidden={i !== 0 ? 'true' : 'false'}
            >
              <article class="card-cita">
                <div class="card-cita__cuerpo">
                  <span class="card-cita__comilla" aria-hidden="true">"</span>
                  <p class="card-cita__texto">{t.texto}</p>
                </div>
                <footer class="card-cita__pie">
                  <span class="card-cita__autor">Participante de Medianeras</span>
                </footer>
              </article>
            </div>
          ))}
        </div>
      </div>

      <!-- Controles verticales -->
      <div class="test-controles" role="group" aria-label="Navegación de testimonios">
        <button class="btn-nav" id="test-prev" type="button" aria-label="Testimonio anterior">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M4 11.5L9 6.5L14 11.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <span class="test-contador" id="test-contador" aria-live="polite">1 / {testimonios.length}</span>
        <button class="btn-nav" id="test-next" type="button" aria-label="Siguiente testimonio">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M4 6.5L9 11.5L14 6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

    </div>

    <div class="test-cta">
      <button class="boton test-cta__btn" id="btn-cmt" type="button">
        Deja tu comentario
      </button>
    </div>
  </div>

  <dialog class="modal-cmt" id="modal-cmt" aria-labelledby="modal-cmt-titulo">
    <div class="modal-cmt__box">

      <div data-panel="form">
        <div class="modal-cmt__header">
          <h3 class="modal-cmt__titulo" id="modal-cmt-titulo">Deja tu comentario</h3>
          <button class="modal-cmt__cerrar js-cerrar-cmt" type="button" aria-label="Cerrar">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4 4L14 14M14 4L4 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <form id="form-cmt">
          <div class="modal-cmt__campo">
            <label class="modal-cmt__label" for="cmt-nombre">Nombre</label>
            <input class="modal-cmt__input" id="cmt-nombre" name="nombre" type="text" placeholder="Tu nombre" required />
          </div>
          <div class="modal-cmt__campo">
            <label class="modal-cmt__label" for="cmt-propuesta">Propuesta</label>
            <input class="modal-cmt__input" id="cmt-propuesta" name="propuesta" type="text" placeholder="Ej: Club de lectura, Taller de escritura…" required />
          </div>
          <div class="modal-cmt__campo">
            <label class="modal-cmt__label" for="cmt-mensaje">Mensaje</label>
            <textarea class="modal-cmt__input modal-cmt__textarea" id="cmt-mensaje" name="mensaje" placeholder="Contanos tu experiencia…" rows="4" required></textarea>
          </div>
          <button class="boton modal-cmt__submit" type="submit">Enviar comentario</button>
        </form>
      </div>

      <div data-panel="exito" hidden>
        <div class="modal-cmt__header">
          <span></span>
          <button class="modal-cmt__cerrar js-cerrar-cmt" type="button" aria-label="Cerrar">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4 4L14 14M14 4L4 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <div class="modal-cmt__exito">
          <p class="modal-cmt__gracias">¡Gracias por tu comentario!</p>
          <p class="modal-cmt__sub">Tu experiencia es muy valiosa para Medianeras.</p>
        </div>
      </div>

    </div>
  </dialog>
</section>

<script>
  const items   = Array.from(document.querySelectorAll<HTMLElement>('.pila__item'));
  const btnPrev = document.getElementById('test-prev')!;
  const btnNext = document.getElementById('test-next')!;
  const contador = document.getElementById('test-contador')!;

  let actual = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  function ir(idx: number) {
    if (idx === actual) return;
    const dir = idx > actual ? 28 : -28;

    // Salida
    items[actual]!.classList.remove('es-activo');
    items[actual]!.setAttribute('aria-hidden', 'true');

    // Entrada: posición inicial sin transición
    const entrante = items[idx]!;
    entrante.style.transition = 'none';
    entrante.style.transform  = `translateY(${dir}px)`;
    entrante.style.opacity    = '0';

    // Doble rAF: primer frame aplica posición, segundo dispara la transición
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        entrante.style.transition = '';
        entrante.style.transform  = '';
        entrante.style.opacity    = '';
        entrante.classList.add('es-activo');
        entrante.setAttribute('aria-hidden', 'false');
      });
    });

    actual = idx;
    contador.textContent = `${actual + 1} / ${items.length}`;
  }

  const sig = () => ir((actual + 1) % items.length);
  const ant = () => ir((actual - 1 + items.length) % items.length);

  function arrancar() {
    if (timer) clearInterval(timer);
    timer = setInterval(sig, 6000);
  }

  btnNext.addEventListener('click', () => { sig(); arrancar(); });
  btnPrev.addEventListener('click', () => { ant(); arrancar(); });

  // Pausa en hover
  const seccion = document.querySelector<HTMLElement>('.testimonios');
  seccion?.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
  seccion?.addEventListener('mouseleave', arrancar);

  // Swipe vertical
  let yStart = 0;
  const track = document.querySelector('.pila__track');
  track?.addEventListener('touchstart', (e) => { yStart = (e as TouchEvent).touches[0]!.clientY; }, { passive: true });
  track?.addEventListener('touchend', (e) => {
    const dy = (e as TouchEvent).changedTouches[0]!.clientY - yStart;
    if (Math.abs(dy) > 44) { dy < 0 ? sig() : ant(); arrancar(); }
  });

  arrancar();
</script>

<script>
  const dialog   = document.querySelector<HTMLDialogElement>('#modal-cmt');
  const form     = document.querySelector<HTMLFormElement>('#form-cmt');
  const panelForm  = dialog?.querySelector<HTMLElement>('[data-panel="form"]');
  const panelExito = dialog?.querySelector<HTMLElement>('[data-panel="exito"]');
  let autoClose: ReturnType<typeof setTimeout> | null = null;

  function abrirModal() {
    form?.reset();
    if (panelForm)  panelForm.hidden  = false;
    if (panelExito) panelExito.hidden = true;
    if (autoClose)  clearTimeout(autoClose);
    dialog?.showModal();
  }

  function cerrarModal() {
    if (autoClose) clearTimeout(autoClose);
    dialog?.close();
  }

  document.getElementById('btn-cmt')?.addEventListener('click', abrirModal);

  dialog?.querySelectorAll<HTMLButtonElement>('.js-cerrar-cmt').forEach((btn) =>
    btn.addEventListener('click', cerrarModal)
  );

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) cerrarModal();
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    if (panelForm)  panelForm.hidden  = true;
    if (panelExito) panelExito.hidden = false;
    autoClose = setTimeout(cerrarModal, 5000);
  });
</script>

<style>
  /* ── Sección ─────────────────────────────────────────────────────────── */
  .testimonios {
    position: relative;
    overflow: clip;
    background: color-mix(in srgb, var(--color-secondary) 9%, var(--color-cream));
  }
  .testimonios .eyebrow { color: var(--color-primary); }

  .testimonios__circulo {
    position: absolute;
    top: var(--space-6);
    left: var(--space-6);
    width: 150px;
    height: 150px;
    animation: girar-test 20s linear infinite;
  }
  @keyframes girar-test {
    to { transform: rotate(360deg); }
  }

  /* ── Layout: pila + controles ────────────────────────────────────────── */
  .test-layout {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-7);
  }

  /* ── Pila ────────────────────────────────────────────────────────────── */
  .test-pila {
    position: relative;
    padding-bottom: 20px; /* espacio para los ghosts que sobresalen */
  }

  /* Cards fantasma debajo de la card activa */
  .pila__ghost {
    position: absolute;
    inset: 0;
    background: var(--color-cream);
    border-radius: var(--radius-card);
    pointer-events: none;
  }
  .pila__ghost--1 {
    transform: translate(0, 8px) scale(0.97);
    opacity: 0.7;
    z-index: 0;
  }
  .pila__ghost--2 {
    transform: translate(0, 15px) scale(0.94);
    opacity: 0.45;
    z-index: -1;
  }

  /* ── Track: todos los items en mismo grid-cell ───────────────────────── */
  .pila__track {
    display: grid;
    position: relative;
    z-index: 1;
  }
  .pila__item {
    grid-area: 1 / 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
    display: flex;
    flex-direction: column;
  }
  .pila__item.es-activo .card-cita {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.08),
      0 4px 12px rgba(0, 0, 0, 0.10),
      0 16px 40px rgba(0, 0, 0, 0.14);
  }

  .pila__item.es-activo {
    opacity: 1;
    transform: translateY(0) !important;
    pointer-events: auto;
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .card-cita {
    background: var(--color-cream);
    border-radius: var(--radius-card);
    position: relative;
    overflow: visible;
    box-shadow: none;
    padding: var(--space-8) var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    height: 100%;
    box-sizing: border-box;
  }

  .card-cita__cuerpo {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-cita__comilla {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 11rem;
    line-height: 1;
    color: var(--color-red);
    position: absolute;
    top: -1.8rem;
    left: var(--space-6);
    user-select: none;
    pointer-events: none;
  }

  .card-cita__texto {
    font-size: var(--text-body-lg);
    line-height: 1.75;
    font-style: italic;
    color: var(--text-main);
    margin: 0;
  }

  .card-cita__pie {
    border-top: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
    padding-top: var(--space-3);
    display: flex;
    justify-content: flex-end;
  }
  .card-cita__autor {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--text-main) 55%, transparent);
  }

  /* ── Controles verticales ────────────────────────────────────────────── */
  .test-controles {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .btn-nav {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid color-mix(in srgb, var(--color-primary) 28%, transparent);
    background: transparent;
    color: var(--color-primary);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base), transform var(--transition-base);
    flex-shrink: 0;
  }
  .btn-nav:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-cream);
    transform: scale(1.08);
  }
  .btn-nav:focus-visible {
    outline: 3px solid var(--color-yellow);
    outline-offset: 2px;
  }

  .test-contador {
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    color: color-mix(in srgb, var(--color-primary) 50%, transparent);
    line-height: 1;
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .test-layout {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }
    .test-controles {
      flex-direction: row;
      justify-content: center;
      order: 2;
      gap: var(--space-5);
    }
    .card-cita {
      padding: var(--space-6) var(--space-5);
    }
    .card-cita__comilla { font-size: 3rem; }
    .card-cita__texto   { font-size: var(--text-body); }
  }

  /* ── Reduced motion ──────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .pila__item { transition: opacity 0.2s ease !important; }
  }

  /* ── Botón CTA comentario ────────────────────────────────────────────── */
  .test-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-7);
  }

  /* ── Modal comentario ────────────────────────────────────────────────── */
  .modal-cmt {
    border: none;
    border-radius: var(--radius-card);
    padding: 0;
    background: var(--color-cream);
    box-shadow: var(--shadow-modal);
    max-width: min(480px, calc(100vw - var(--space-8)));
    width: 100%;
    position: fixed;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    margin: 0;
  }
  .modal-cmt::backdrop {
    background: rgba(41, 72, 76, 0.55);
    backdrop-filter: blur(4px);
  }
  .modal-cmt__box {
    padding: var(--space-7);
  }
  .modal-cmt__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }
  .modal-cmt__titulo {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
  }
  .modal-cmt__cerrar {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .modal-cmt__cerrar:hover {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
  }
  .modal-cmt__campo {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }
  .modal-cmt__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-main);
  }
  .modal-cmt__input {
    padding: var(--space-3) var(--space-4);
    border: 1.5px solid color-mix(in srgb, var(--color-primary) 25%, transparent);
    border-radius: var(--radius-md);
    background: #fff;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--text-main);
    transition: border-color var(--transition-fast);
  }
  .modal-cmt__input:focus {
    outline: none;
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-secondary) 25%, transparent);
  }
  .modal-cmt__textarea {
    resize: vertical;
    min-height: 100px;
  }
  .modal-cmt__submit {
    width: 100%;
    margin-top: var(--space-2);
  }
  .modal-cmt__exito {
    padding: var(--space-8) 0 var(--space-5);
    text-align: center;
  }
  .modal-cmt__gracias {
    font-size: var(--text-h2);
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
  }
  .modal-cmt__sub {
    font-size: var(--text-body);
    color: var(--text-muted);
    margin: 0;
  }
</style>

---
// Footer.astro — 2 cols: marca izquierda, links derecha.
// Links: sin subrayado base, underline grueso amarillo en hover (artístico).
import type { ConfigSitio } from '../lib/types';

interface Props {
  config: ConfigSitio;
}
const { config } = Astro.props;
const igUser = config.instagram.replace('@', '');
const anio = new Date().getFullYear();
---
<footer class="pie seccion--oscura">
  <div class="pie__acento" aria-hidden="true"></div>

  <div class="contenedor pie__cuerpo">

    <!-- Columna 1: Marca -->
    <div class="pie__marca">
      <img
        src="/brand/logo-oscuro.png"
        alt="Medianeras — Libros Cultura Encuentros"
        class="pie__logo"
        loading="lazy"
      />
      <p class="pie__frase">Los libros están para ser leídos y conversados.</p>
    </div>

    <!-- Columna 2: Links -->
    <div class="pie__links">

      <nav class="pie__nav" aria-label="Secciones del sitio">
        <p class="pie__col-titulo">Secciones</p>
        <ul>
          <li><a href="#quienes">Quiénes somos</a></li>
          <li><a href="#propuestas">Propuestas</a></li>
          <li><a href="#testimonios">Testimonios</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </nav>

      <div class="pie__contacto">
        <p class="pie__col-titulo">Contacto</p>
        <ul>
          <li class="pie__dato">
            <span class="pie__dato-label">escribinos</span>
            <a href={`mailto:${config.emailContacto}`}>{config.emailContacto}</a>
          </li>
          {config.whatsapp && (
            <li class="pie__dato">
              <span class="pie__dato-label">whatsapp</span>
              <a href={`https://wa.me/${config.whatsapp}`} rel="noopener">Escribinos</a>
            </li>
          )}
          <li class="pie__dato">
            <span class="pie__dato-label">seguinos</span>
            <a href={`https://instagram.com/${igUser}`} rel="noopener">{config.instagram}</a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <div class="contenedor pie__bottom">
    <span>© {anio} medianeras · Rafaela, Santa Fe</span>
    <span>Sitio por <a href="https://harvi.digital" rel="noopener" target="_blank" class="pie__harvi">Harvi Digital</a></span>
  </div>
</footer>

<style>
  /* ── Acento amarillo ─────────────────────────────────────────────────── */
  .pie__acento {
    height: 4px;
    background: var(--color-yellow);
  }

  /* ── Cuerpo: 2 columnas ──────────────────────────────────────────────── */
  .pie__cuerpo {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-9);
    padding-block: var(--space-8);
  }

  /* ── Col 1: Marca ────────────────────────────────────────────────────── */
  .pie__marca {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* object-fit: contain para que nunca se deforme, sin importar dimensiones reales */
  .pie__logo {
    width: min(100%, 220px);
    height: 110px;
    object-fit: contain;
    object-position: left center;
    display: block;
  }

  .pie__frase {
    font-size: var(--text-body);
    font-weight: 700;
    font-style: italic;
    color: var(--color-secondary);
    line-height: 1.45;
    max-width: 30ch;
    margin: 0;
  }

  /* ── Col 2: Links ────────────────────────────────────────────────────── */
  .pie__links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }

  /* Títulos de columna con subrayado */
  .pie__col-titulo {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin: 0 0 var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid color-mix(in srgb, var(--color-secondary) 35%, transparent);
    width: fit-content;
  }

  .pie__nav ul,
  .pie__contacto ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* ── Links: base sin subrayado, hover con underline grueso artístico ─── */
  .pie__nav a,
  .pie__contacto a {
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .pie__nav a {
    color: color-mix(in srgb, var(--color-cream) 70%, transparent);
    font-weight: 500;
  }
  .pie__contacto a {
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
  }

  .pie__nav a:hover,
  .pie__contacto a:hover {
    color: var(--color-cream);
    text-decoration: underline;
    text-decoration-color: var(--color-yellow);
    text-decoration-thickness: 3px;
    text-underline-offset: 5px;
  }

  .pie__dato {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pie__dato-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-cream) 38%, transparent);
  }

  /* ── Barra inferior ──────────────────────────────────────────────────── */
  .pie__harvi {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--color-yellow);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }
  .pie__harvi:hover {
    color: var(--color-cream);
  }

  /* ── Barra inferior ──────────────────────────────────────────────────── */
  .pie__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-5);
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 10%, transparent);
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--color-cream) 32%, transparent);
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .pie__cuerpo { grid-template-columns: 1fr; gap: var(--space-7); }
    .pie__links  { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .pie__links { grid-template-columns: 1fr; }
  }
</style>

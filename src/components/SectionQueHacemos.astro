---
// SectionQueHacemos.astro — R02. Filosofía + 4 áreas con íconos Lucide.
import { mdToHtml } from '../lib/markdown';
import { UI } from '../content/ui';
import type { ConfigSitio } from '../lib/types';

interface Props {
  config: ConfigSitio;
}
const { config } = Astro.props;

const COLORES = ['var(--color-yellow)', 'var(--color-red)', 'var(--color-secondary)', 'var(--color-olive)'];

// Lucide icon paths (stroke, viewBox 0 0 24 24)
// flor → BookOpen (Lectura)
// margarita → Lightbulb (Pensamiento)
// rama → MessageCircle (Comunicación)
// hoja → Landmark (Cultura)
const LUCIDE: Record<string, string> = {
  flor: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 0 3-3h7z"/>',
  margarita: '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  rama: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
  hoja: '<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/>',
};
---
<section class="seccion seccion--oscura que-hacemos" id="que-hacemos" aria-labelledby="qh-titulo">
  <div class="contenedor">
    <p class="eyebrow">Qué hacemos</p>
    <h2 id="qh-titulo" class="label-seccion">{UI.queHacemos.titulo}</h2>

    <ul class="qh__areas">
      {UI.queHacemos.areas.map((a, i) => (
        <li class="area">
          <span class="area__icono" style={`--c:${COLORES[i % COLORES.length]}`}>
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={LUCIDE[a.icono] ?? LUCIDE.flor}
            />
          </span>
          <h3 class="area__nombre">{a.nombre}</h3>
          <p class="area__texto">{a.texto}</p>
        </li>
      ))}
    </ul>

    <div class="qh__divisor" aria-hidden="true">
      <span class="qh__divisor-linea"></span>
      <img class="qh__divisor-sello" src="/brand/svg_elements/circle/conocimiento.svg" alt="" width="64" height="64" loading="lazy" />
      <span class="qh__divisor-linea"></span>
    </div>

    <div class="qh__filosofia" set:html={mdToHtml(config.filosofia)} />
  </div>
</section>

<style>
  .qh__divisor {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin: var(--space-8) 0;
  }
  .qh__divisor-linea {
    flex: 1;
    height: 2px;
    background: var(--color-yellow);
    border-radius: 2px;
  }
  .qh__divisor-sello {
    flex-shrink: 0;
    animation: girar-qh 22s linear infinite;
  }
  @keyframes girar-qh {
    to { transform: rotate(360deg); }
  }

  .qh__filosofia {
    margin: 0;
  }
  .qh__filosofia :global(p) {
    font-size: var(--text-body-lg);
    color: var(--text-on-dark);
    margin-bottom: var(--space-1);
    line-height: 1.6;
    text-align: center;
  }
  .qh__filosofia :global(em) {
    color: var(--color-secondary);
    font-style: italic;
  }

  .qh__areas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }
  .area {
    background: color-mix(in srgb, var(--color-cream) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-secondary) 30%, transparent);
    border-radius: var(--radius-card);
    padding: var(--space-6);
  }
  .area__icono {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--c);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    flex-shrink: 0;
  }
  .area__nombre {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--text-on-dark);
    margin-bottom: var(--space-2);
  }
  .area__texto {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
  }
</style>
